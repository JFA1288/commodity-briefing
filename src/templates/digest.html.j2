<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ cfg.dashboard.site_title }} — {{ date_str }}</title>
<style>
:root {
  --bg: #f8f9fa; --surface: #fff; --border: #e2e6ea;
  --text: #212529; --muted: #6c757d; --accent: #0d6efd;
  --up: #198754; --dn: #dc3545; --warn: #fd7e14;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
}
@media(prefers-color-scheme:dark){
  :root{--bg:#0f1117;--surface:#1a1d24;--border:#2d3139;--text:#e8eaf0;--muted:#9098a9;--accent:#4d8ef9;}
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);line-height:1.6;font-size:15px}
a{color:var(--accent);text-decoration:none}a:hover{text-decoration:underline}
.wrap{max-width:900px;margin:0 auto;padding:2rem 1.25rem}
header{margin-bottom:2.5rem;border-bottom:1px solid var(--border);padding-bottom:1.5rem}
header h1{font-size:1.5rem;font-weight:700;letter-spacing:-.02em}
header .meta{color:var(--muted);font-size:.85rem;margin-top:.35rem}
h2{font-size:1.1rem;font-weight:700;margin:2rem 0 .9rem;letter-spacing:-.01em;border-left:3px solid var(--accent);padding-left:.65rem}
h3{font-size:.95rem;font-weight:600;margin:.75rem 0 .4rem}
.card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:1.1rem 1.25rem;margin-bottom:.75rem}
.tag{display:inline-block;font-size:.72rem;font-weight:600;letter-spacing:.03em;text-transform:uppercase;padding:.18rem .5rem;border-radius:4px;margin-right:.35rem;background:rgba(13,110,253,.1);color:var(--accent)}
.tag.earnings{background:rgba(25,135,84,.12);color:#198754}
.tag.ma{background:rgba(13,202,240,.12);color:#0dcaf0}
.tag.outage{background:rgba(220,53,69,.12);color:#dc3545}
.tag.regulatory{background:rgba(253,126,20,.12);color:#fd7e14}
.tag.geopolitical{background:rgba(111,66,193,.12);color:#6f42c1}
.tag.price_shock{background:rgba(220,53,69,.12);color:#dc3545}
.headline{padding:.65rem 0;border-bottom:1px solid var(--border)}
.headline:last-child{border-bottom:none}
.headline .src{font-size:.78rem;color:var(--muted);margin-top:.2rem}
.up{color:var(--up)} .dn{color:var(--dn)} .na{color:var(--muted)}
.badge{display:inline-block;font-size:.72rem;padding:.15rem .45rem;border-radius:3px;font-weight:600}
.badge.yfinance{background:rgba(25,135,84,.12);color:#198754}
.badge.web{background:rgba(253,126,20,.15);color:#fd7e14}
.badge.unavailable{background:rgba(108,117,125,.12);color:var(--muted)}
.watch-list{list-style:none}
.watch-list li{padding:.55rem 0;border-bottom:1px solid var(--border)}
.watch-list li:last-child{border-bottom:none}
.watch-list .cat{display:inline-block;width:100px;font-size:.72rem;text-transform:uppercase;font-weight:700;color:var(--muted)}
details summary{cursor:pointer;user-select:none;font-weight:600;list-style:none;display:flex;align-items:center;gap:.4rem}
details summary::-webkit-details-marker{display:none}
details summary::before{content:"▶";font-size:.65rem;transition:transform .15s;display:inline-block}
details[open] summary::before{transform:rotate(90deg)}
</style>
</head>
<body>
<div class="wrap">

<header>
  <h1>{{ cfg.dashboard.site_title }}</h1>
  <div class="meta">Daily digest — {{ utc_time }} / {{ sgt_time }}</div>
  <div class="meta" style="margin-top:.5rem"><a href="../index.html">← Live Dashboard</a></div>
</header>

<!-- What to Watch -->
{% if digest.what_to_watch %}
<h2>What to Watch</h2>
<div class="card">
  <ul class="watch-list">
    {% for b in digest.what_to_watch %}
    <li><span class="cat">{{ b.category | replace('_',' ') }}</span> {{ b.text }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<!-- Top Headlines -->
<h2>Top Headlines</h2>
<div class="card">
  {% for item in digest.top_headlines %}
  <div class="headline">
    <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
    {% for f in item.flags %}<span class="tag {{ f }}">{{ f }}</span>{% endfor %}
    <div class="src">{{ item.source }}{% if item.published %} · {{ item.published.strftime('%b %d %H:%M UTC') }}{% endif %}</div>
  </div>
  {% else %}
  <p style="color:var(--muted);font-size:.9rem">No headlines available.</p>
  {% endfor %}
</div>

<!-- Prices -->
<h2>Commodity Prices</h2>
<div class="card">
  <table style="width:100%;border-collapse:collapse;font-size:.9rem">
    <thead>
      <tr style="border-bottom:2px solid var(--border);color:var(--muted);font-size:.78rem;text-transform:uppercase">
        <th style="text-align:left;padding:.4rem .5rem">Commodity</th>
        <th style="text-align:right;padding:.4rem .5rem">Price</th>
        <th style="text-align:right;padding:.4rem .5rem">Change</th>
        <th style="text-align:right;padding:.4rem .5rem">Source</th>
      </tr>
    </thead>
    <tbody>
    {% for p in digest.prices %}
    <tr style="border-bottom:1px solid var(--border)">
      <td style="padding:.45rem .5rem">{{ p.display }}</td>
      <td style="text-align:right;padding:.45rem .5rem;font-variant-numeric:tabular-nums">
        {% if p.price %}{{ "%.2f"|format(p.price) }} <small style="color:var(--muted)">{{ p.unit }}</small>{% else %}<span class="na">—</span>{% endif %}
      </td>
      <td style="text-align:right;padding:.45rem .5rem;font-variant-numeric:tabular-nums">
        {% if p.change_pct is not none %}
          <span class="{{ 'up' if p.change_pct >= 0 else 'dn' }}">{{ "%+.1f"|format(p.change_pct) }}%</span>
        {% else %}<span class="na">—</span>{% endif %}
      </td>
      <td style="text-align:right;padding:.45rem .5rem">
        <span class="badge {{ p.source }}">{{ p.source }}</span>
      </td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<!-- Company News -->
{% set sectors = {'energy':'Energy','metals_mining':'Metals & Mining','power_utilities':'Power & Utilities','trading':'Trading'} %}
{% for sector_key, sector_label in sectors.items() %}
{% set sector_companies = digest.companies | selectattr('sector','equalto',sector_key) | list %}
{% if sector_companies %}
<h2>{{ sector_label }}</h2>
{% for company in sector_companies %}
<div class="card">
  <details>
    <summary>
      {{ company.name }}
      {% for f in company.flags %}<span class="tag {{ f }}">{{ f }}</span>{% endfor %}
    </summary>
    <div style="margin-top:.75rem">
    {% for item in company.items %}
    <div class="headline">
      <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
      {% for f in item.flags %}<span class="tag {{ f }}">{{ f }}</span>{% endfor %}
      <div class="src">{{ item.source }}{% if item.published %} · {{ item.published.strftime('%b %d %H:%M UTC') }}{% endif %}</div>
    </div>
    {% else %}
    <p style="color:var(--muted);font-size:.85rem;margin-top:.5rem">No recent news.</p>
    {% endfor %}
    </div>
  </details>
</div>
{% endfor %}
{% endif %}
{% endfor %}

<!-- Commodity News -->
{% for cd in digest.commodities %}
{% if cd.items %}
<h2>{{ cd.display }}</h2>
<div class="card">
  {% for item in cd.items %}
  <div class="headline">
    <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
    {% for f in item.flags %}<span class="tag {{ f }}">{{ f }}</span>{% endfor %}
    <div class="src">{{ item.source }}{% if item.published %} · {{ item.published.strftime('%b %d %H:%M UTC') }}{% endif %}</div>
  </div>
  {% endfor %}
</div>
{% endif %}
{% endfor %}

<footer style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);color:var(--muted);font-size:.8rem">
  Generated {{ utc_time }} · Rule-based extractive digest · Prices from yfinance (live) and web (indicative) · No LLM used
</footer>
</div>
</body>
</html>
